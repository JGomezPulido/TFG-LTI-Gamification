TK_SECRET="SECRET FOR PASSWORD HASHING"
MOODLE_IP="BASE IP OF YOUR MOODLE SERVER"
MOODLE_TK="CLIENT TOKEN FOR YOUR MOODLE WEB SERVICES API"
FRONTEND_IP="IP OF YOUR FRONTEND"
PORT=3443
